# Copy this file to `.env` and fill in real values before running `docker compose up`.
# `.env` is gitignored so secrets never land in the repo.

# --- Postgres (used by the `postgres` service itself) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=gharchive

# Host port that maps to the container's 5432.
# Override if 5433 is already taken on your machine.
POSTGRES_HOST_PORT=5433

# --- Application services (seed / scheduler / transform / mcp_server) ---
# These point app containers at the `postgres` service on the compose network,
# so DB_HOST stays as the service name, not `localhost`.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gharchive
DB_USER=postgres
DB_PASSWORD=changeme

# --- Pipeline tuning ---
PIPELINE_WORKERS=4

# --- MCP server transport ---
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
